<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
    xmlns:tizen="http://tizen.org/ns/widgets"
    id="http://akantolas.com/AkantronicsIPTV"
    version="0.1.0"
    viewmodes="maximized">
    <tizen:application id="akantolas.AkantronicsIPTV" package="akantolas.AkantronicsIPTV" required_version="6.0" />
    <content src="index.html" />
    <feature name="http://tizen.org/feature/screen.size.all" />
    <feature name="http://tizen.org/feature/network.internet" />
    <icon src="icon.png" />
    <name>Akantronics IPTV</name>
    <description>Samsung Smart TV IPTV player</description>
    <author href="https://github.com/akantolas" email="dev@akantolas.com">Akantronics</author>
    <tizen:profile name="tv" />
    <tizen:setting screen-orientation="landscape" context-menu="enable" background-support="disable" encryption="disable" install-location="auto" hwkey-event="enable" />
    <tizen:privilege name="http://tizen.org/privilege/internet" />
    <tizen:privilege name="http://tizen.org/privilege/tv.inputdevice" />
    <tizen:privilege name="http://tizen.org/privilege/tv.audio" />
    <tizen:privilege name="http://tizen.org/privilege/tv.display" />
    <tizen:privilege name="http://tizen.org/privilege/tv.window" />
    <tizen:privilege name="http://tizen.org/privilege/content.read" />
    <tizen:privilege name="http://tizen.org/privilege/content.write" />
    <tizen:privilege name="http://developer.samsung.com/privilege/network.public" />
    <tizen:privilege name="http://developer.samsung.com/privilege/avplay" />
    <tizen:privilege name="http://developer.samsung.com/privilege/drmplay" />
    <access origin="*" subdomains="true" />
    <tizen:content-security-policy>default-src * 'unsafe-inline' 'unsafe-eval' data: blob:; connect-src *; img-src * data: blob:; media-src * blob:;</tizen:content-security-policy>
</widget>
