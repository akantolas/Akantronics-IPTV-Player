{
  "name": "@tv/tizen-tv",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build --workspace=@tv/xtream-core && vite build",
    "package:wgt": "npm run build && node scripts/package-wgt.mjs",
    "deploy": "npm run package:wgt && tizen install -n AkantronicsIPTV.wgt -s 192.168.1.104:26101 -- dist",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tv/xtream-core": "*"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
